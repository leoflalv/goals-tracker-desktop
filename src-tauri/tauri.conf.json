{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Goals Tracker",
  "version": "0.1.0",
  "identifier": "com.leoflalv.goals-tracker-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Goals Tracker",
        "width": 320,
        "height": 480,
        "x": 20,
        "y": 40,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
